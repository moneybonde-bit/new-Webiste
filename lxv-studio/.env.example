# ============================================================
# Luxavian — environment variables
# Copy to `.env` for local development. For production, set these
# as BUILD-TIME variables in Cloudflare (Workers & Pages → your
# project → Settings → Variables) — Vite inlines them at build,
# they are NOT read at runtime.
#
# Leave both unset to run the portal in zero-config demo mode
# (data persists in the browser's localStorage).
# ============================================================

# From Supabase → your project → Settings → API → "Project URL"
# e.g. https://abcdefghij.supabase.co
VITE_SUPABASE_URL=

# From Supabase → Settings → API → "anon / public" key.
# Safe to expose in the browser: Row Level Security governs all access.
# NEVER put the service_role key here.
VITE_SUPABASE_ANON_KEY=

# ------------------------------------------------------------
# Edge-function secrets (set on Supabase, NOT here / NOT in Cloudflare):
#   supabase secrets set RESEND_API_KEY=re_xxx          # resend.com → API Keys
#   supabase secrets set NOTIFY_FROM="Luxavian <hello@luxavian.id>"
#   supabase secrets set PORTAL_URL=https://luxavian.it.com/portal
# ------------------------------------------------------------
